{
  "name": "@lynxtron-examples/config",
  "version": "0.0.2-alpha.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./lynx": {
      "types": "./dist/lynx.config.d.ts",
      "default": "./dist/lynx.config.js"
    },
    "./window": {
      "types": "./dist/window.d.ts",
      "default": "./dist/window.js"
    },
    "./tokens.css": "./tokens.css"
  },
  "files": [
    "dist",
    "tokens.css"
  ],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@lynx-js/config-rsbuild-plugin": "catalog:",
    "@lynx-js/react-rsbuild-plugin": "catalog:",
    "@lynx-js/rspeedy": "catalog:",
    "@lynx-js/type-config": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
