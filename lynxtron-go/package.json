{
  "name": "lynxtron-go",
  "version": "0.0.1",
  "main": "main.js",
  "files": [
    "dist/**",
    "src/**",
    "scintilla-extension/**",
    "docs/**",
    "scripts/**",
    "*.ts",
    "*.yml",
    "*.json",
    "*.md",
    "*.svg"
  ],
  "scripts": {
    "build:scintilla-extension": "pnpm --dir ./scintilla-extension run build",
    "build:http-service-extension": "pnpm --dir ./http-service-extension run build",
    "dev": "cross-env TARGET_ENV=desktop NODE_ENV=development concurrently -k --raw \"rspeedy dev\" \"dev-ready-rspeedy && rspack dev\"",
    "run-dev": "lynxtron ./dist/desktop --inspect=9222",
    "debug:detached": "node scripts/start_debug.js",
    "prepare:runtime-deps": "node scripts/prepare-runtime-deps.js",
    "prepare:builder-patches": "node scripts/ensure-builder-patches.js",
    "build": "npm run build:http-service-extension && npm run build:scintilla-extension && rspeedy build && rspack build",
    "start": "cross-env TARGET_ENV=desktop npm run build && lynxtron ./dist/desktop",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p src/app/tsconfig.json && tsc --noEmit -p src/main/desktop/tsconfig.json",
    "pack:win": "npm run build && npm run prepare:runtime-deps && npm run prepare:builder-patches && lynxtron-builder --win --x64 --publish never",
    "pack": "npm run build && npm run prepare:runtime-deps && npm run prepare:builder-patches && lynxtron-builder --publish never"
  },
  "private": true,
  "showcase": {
    "description": "Lynxtron GO — IDE playground for Lynxtron showcases",
    "thumbnail": "thumbnail.png",
    "tags": [
      "ide",
      "self-host"
    ],
    "minToolchainVersion": "0.0.1"
  },
  "dependencies": {
    "@isaacs/fs-minipass": "^4.0.0",
    "@lynxtron-examples/cli": "workspace:*",
    "chownr": "^3.0.0",
    "lynxtron-http-service": "workspace:*",
    "lynxtron-scintilla-editor": "workspace:*",
    "minipass": "^7.1.2",
    "minizlib": "^3.1.0",
    "prismjs": "^1.30.0",
    "tar": "^7.0.0",
    "typescript": "catalog:",
    "vscode-css-languageservice": "^6.3.10",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-languageserver-types": "^3.17.5",
    "yallist": "^5.0.0"
  },
  "__commented_out_dependencies": {
  },
  "devDependencies": {
    "@lynx-js/lynxtron": "catalog:",
    "@lynx-js/lynxtron-builder": "catalog:",
    "@lynx-js/lynxtron-dev-plugins": "catalog:",
    "@lynx-js/config-rsbuild-plugin": "catalog:",
    "@lynx-js/lynx-core": "latest",
    "@lynx-js/react": "catalog:",
    "@lynx-js/react-rsbuild-plugin": "catalog:",
    "@lynx-js/rspeedy": "catalog:",
    "@lynx-js/type-config": "catalog:",
    "@lynx-js/types": "catalog:",
    "app-builder-lib": "26.8.1",
    "dmg-builder": "26.8.1",
    "@rsbuild/plugin-type-check": "1.3.1",
    "@rspack/cli": "catalog:",
    "@rspack/core": "catalog:",
    "patch-package": "^6.4.7",
    "@testing-library/jest-dom": "^6.9.0",
    "@types/node": "^22.0.0",
    "@types/prismjs": "^1.26.6",
    "compressing": "^1.10.0",
    "concurrently": "catalog:",
    "cross-env": "catalog:",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  }
}
