{
  "name": "lynxtron-scintilla-editor",
  "author": "Lynxtron Authors",
  "version": "0.0.1",
  "type": "module",
  "main": "index.cjs",
  "description": "Lynxtron Scintilla Editor Extension",
  "scripts": {
    "build": "node scripts/build.js",
    "postinstall": "node scripts/prepare.js"
  },
  "keywords": [
    "lynx",
    "extension",
    "scintilla"
  ],
  "files": [
