    "scripts/**/*",
    "build/Release/*.node"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "node-addon-api": "^7.0.0"
  },
  "devDependencies": {
    "@lynx-js/lynx-library-headers": "catalog:",
    "cmake-js": "^7.3.0"
  }
